{
  "name": "xjmvvm-docs",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "XjMVVM reboot documentation using the Pi Analysis Docs reader style",
  "scripts": {
    "build": "node tools/embed-fonts.mjs && node tools/build.mjs",
    "fonts": "node tools/embed-fonts.mjs",
    "read": "node tools/serve.mjs",
    "comments": "node tools/list-comments.mjs",
    "serve": "python3 -m http.server 8000 -d site"
  },
  "devDependencies": {
    "highlight.js": "11.10.0",
    "marked": "18.0.7"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@fontsource/noto-sans-thai-looped": "^5.2.10"
  }
}
